# 你的访问域名。建议先用 listen.techfone.xyz。
APP_DOMAIN=listen.techfone.xyz

# Caddy 申请 HTTPS 证书时使用的邮箱。
ACME_EMAIL=admin@techfone.xyz

# 后端服务端口，通常不用改。
PORT=3001

# 后端应用数据目录。AList WebDAV 配置会由 App 页面写入这里，不需要手工填写到 .env.production。
APP_DATA_DIR=/app/data

# 用户账号优先使用 MySQL。配置后后端会自动创建 my_read_users 表。
# 如果不配置这些变量，本地开发会回退到 /app/data/users.json。
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# AList WebDAV 可直接在 App 的“我的 -> AList 网盘授权”页面配置。
# 如果要用环境变量预置，也可以填写下面这些值。
WEBDAV_BASE_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_ROOT_PATH=/
WEBDAV_BOOK_TITLE=我的听书

# 本地音频目录（默认优先来源）
LOCAL_LIBRARY_ENABLED=true
LOCAL_LIBRARY_ROOT=/app/data/library
LOCAL_LIBRARY_BOOK_TITLE=本地听书
