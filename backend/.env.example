PORT=3001

# 阿里云盘/PDS OpenAPI 域名；如你的授权服务不同，可改这里。
ALIYUN_API_BASE=https://openapi.alipan.com

# 可选：OAuth refresh token 端点。不同授权来源可能不一致，留空时只使用 ALIYUN_ACCESS_TOKEN。
ALIYUN_TOKEN_ENDPOINT=
ALIYUN_CLIENT_ID=
ALIYUN_CLIENT_SECRET=

# 必填：后端持有，不会暴露给浏览器。
ALIYUN_ACCESS_TOKEN=
ALIYUN_REFRESH_TOKEN=
ALIYUN_DRIVE_ID=
ALIYUN_ROOT_FILE_ID=root
ALIYUN_BOOK_TITLE=我的听书
